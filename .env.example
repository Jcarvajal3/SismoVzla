# API Key del motor de análisis (Gemini)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...tu_key_aquí

# Supabase
# Obtener en: https://app.supabase.com → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...tu_service_role_key

# CORS — Origen permitido para tus API endpoints
# En producción, poner tu dominio exacto (ej: https://sismoseguro.vercel.app)
# En desarrollo local no es necesario (localhost ya está permitido por defecto)
ALLOWED_ORIGIN=https://tu-app.vercel.app
